# Runtime-generated sentinel files (created by main.nf each run).
# Must NOT be tracked — otherwise a local run blocks `git pull` with
# "untracked working tree files would be overwritten by merge".
assets/NO_GTF
assets/EMPTY_SPIKE.fa
assets/EMPTY_SPIKE_INDEX.fa

