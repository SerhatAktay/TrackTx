// ════════════════════════════════════════════════════════════════════════════
// TrackTx Pipeline Configuration — Universal Auto-Adaptive Setup
// ════════════════════════════════════════════════════════════════════════════
//
// Automatically adapts to any environment (laptop → HPC) with smart defaults
// Resources allocated based on tool efficiency benchmarks
// No manual tuning needed!
//
// Quick Start:
//   Desktop/Mac:    -profile docker
//   Linux:          -profile conda
//   HPC:            -profile slurm,singularity
//   NFS Issues:     -profile conda_server
//   External drive: -profile docker,performance (or conda,performance)
//
// NOTE: CPU/memory helper functions live in the `params.res` map below.
//       Under the NF26 strict config parser, lib/*.groovy classes are NOT
//       visible to config closures, so they must be defined inline here.
//
// ════════════════════════════════════════════════════════════════════════════

// ════════════════════════════════════════════════════════════════════════════
// MANIFEST
// ════════════════════════════════════════════════════════════════════════════

manifest {
  name            = 'tracktx'
  author          = 'Serhat Aktay <serhat.aktay@scilifelab.se>'
  description     = 'Nextflow pipeline for nascent RNA analysis (PRO-seq, GRO-seq)'
  homePage        = 'https://github.com/serhataktay/tracktx'
  version         = '3.0'
  mainScript      = 'main.nf'
  nextflowVersion = '>=26.04.0'
}

// ════════════════════════════════════════════════════════════════════════════
// DEFAULT PARAMETERS
// ════════════════════════════════════════════════════════════════════════════

params {
  // ──────────────────────────────────────────────────────────────────────────
  // Adaptive CPU/Memory helpers (Nextflow 26+ compatible)
  //
  // These MUST live here as closures, NOT in lib/*.groovy: under the NF26 strict
  // config parser (ConfigDsl v2), classes from lib/ are NOT visible to config
  // closures, so `ResourceUtils.x()` throws "No such variable: ResourceUtils"
  // when a process resource closure is evaluated. Storing them under params keeps
  // them in the binding that resource closures see at task-submission time.
  //
  // NOTE: use `(expr as int)` casts, never Java-style `(int)expr` — the strict
  // parser reads `(int)(x)` as `int.call(x)` and throws MissingMethodException.
  // ──────────────────────────────────────────────────────────────────────────
  res = [
    // ── System detection ──
    detectCpus: {
      def cpus    = Runtime.runtime.availableProcessors()
      def envCpus = System.getenv('NXF_HOST_CPUS')
      envCpus ? (envCpus as Integer) : cpus
    },
    detectMemoryGb: {
      try {
        def osBean = java.lang.management.ManagementFactory.operatingSystemMXBean
        def method = osBean.class.getMethod('getTotalPhysicalMemorySize')
        long totalBytes = (method.invoke(osBean) as Long)
        Math.max(2, ((totalBytes >> 30) as int))
      } catch (Exception _e) {
        def envMem = System.getenv('NXF_HOST_MEM')
        envMem ? (envMem as Integer) : 8
      }
    },
    systemCpus:     { Math.max(1, params.res.detectCpus()) },
    systemMemoryGb: { Math.max(2, params.res.detectMemoryGb()) },

    // ── Tool-specific CPU allocation ──
    alignmentCpus: {
      def t = params.res.systemCpus()
      if (t <= 4)  return t
      if (t <= 8)  return 4
      if (t <= 12) return 5
      if (t <= 16) return 6
      if (t <= 32) return 6
      return 8
    },
    alignmentForks: {
      def t = params.res.systemCpus()
      if (t < 8) return 1
      Math.max(1, ((t / params.res.alignmentCpus()) as int))
    },
    preprocessCpus: {
      def t = params.res.systemCpus()
      if (t <= 4) return Math.max(2, t - 1)
      return 4
    },
    tracksCpus: {
      def t = params.res.systemCpus()
      if (t <= 4) return t
      return 4
    },
    normCpus: {
      def t = params.res.systemCpus()
      if (t <= 4) return 2
      return 4
    },
    divergentCpus: {
      def t = params.res.systemCpus()
      if (t <= 4)  return t
      if (t <= 8)  return 4
      if (t <= 16) return 8
      if (t <= 32) return 8
      return 8
    },
    indexCpus: {
      def t = params.res.systemCpus()
      if (t <= 4)  return t
      if (t <= 8)  return 6
      if (t <= 16) return 8
      if (t <= 32) return 12
      return 16
    },
    analysisCpus: {
      def t = params.res.systemCpus()
      if (t <= 4)  return 2
      if (t <= 8)  return 2
      if (t <= 16) return 3
      return 4
    },
    lightweightCpus: { 1 },

    // ── Memory allocation ──
    intensiveMemory: { base = 8 ->
      def g = params.res.systemMemoryGb()
      if (g <= 8)       return "${Math.max(4, ((g * 0.8) as int))} GB"
      else if (g <= 32) return "${Math.min(((base * 2) as int), ((g * 0.5) as int))} GB"
      else              return "${Math.min(((base * 3) as int), ((g * 0.6) as int))} GB"
    },
    moderateMemory: { base = 4 ->
      def g = params.res.systemMemoryGb()
      if (g <= 8)       return "${Math.max(2, ((g * 0.4) as int))} GB"
      else if (g <= 32) return "${Math.min(((base * 1.5) as int), ((g * 0.3) as int))} GB"
      else              return "${Math.min(((base * 2) as int), ((g * 0.4) as int))} GB"
    },
    lightMemory: {
      def g = params.res.systemMemoryGb()
      if (g <= 8)  return "1 GB"
      if (g <= 32) return "2 GB"
      return "4 GB"
    },
    alignmentMemory: {
      def g = params.res.systemMemoryGb()
      def f = params.res.alignmentForks()
      if (g <= 8) return "${((g * 0.8) as int)} GB"
      else if (g <= 32) {
        def perTask = Math.max(8, (((g * 0.6) / Math.max(1, f)) as int))
        return "${Math.min(16, (perTask as int))} GB"
      } else {
        def perTask = Math.max(12, (((g * 0.5) / Math.max(1, f)) as int))
        return "${Math.min(24, (perTask as int))} GB"
      }
    }
  ]

  // Core Paths (override via params.yaml or command line)
  output_dir    = './results'
  assets_dir    = "${projectDir}/assets"
  genome_cache  = "${projectDir}/.cache/genomes"

  // Control Flags
  help          = false
  debug         = false
  verbose       = false
  debug_report  = false
  force_rebuild = false
  paired_end    = false

  // Library type: controls R1 strand handling at alignment
  //   'proseq'  (default) — R1 is reverse-complemented before alignment
  //              (reads capture the 3' end of nascent RNA; standard PRO-seq/PRO-cap)
  //   'groseq'            — R1 is aligned as-is; no reverse-complement applied
  //              (reads already represent the nascent RNA strand; standard GRO-seq)
  library_type  = 'proseq'

  // Reporting
  reports_plots = 0

  // Divergent Transcription (v3.0)
  advanced = [:]

  // Feature Toggles
  fastqc_raw               = true
  counts_allow_index_build = true
  force_sort_bedgraph      = false
  preprocess_reads_lenient_cache = false  // Set true for NFS/network storage to avoid cache invalidation
  publish_mode             = 'link'       // 'copy' for external drives (exFAT/USB/NAS) - hard links fail on exFAT
  publish_trimmed_fastq    = true        // false = skip 01_trimmed_fastq (~900 MB saved per sample)
                                         //   WARNING: also disables the SRR re-run shortcut (trimmed FASTQs won't exist to check)
  publish_alignments       = true        // false = skip 02_alignments (~270 MB per sample)
  publish_sra_fastq        = true        // false = hide SRA cache under results/.sra_cache (not visible in results)
  publish_references_gtf   = true        // false = skip GTF file in references output (~790 MB saved)

  // Module-Specific Settings
  adapter_trimming = [:]
  barcode          = [:]
  umi              = [:]
  output           = [:]

  norm = [
    emit_bw:            true,
    emit_sicpm:         true,
    emit_allmap:        true,
    emit_5p:            null,   // null = auto-detect; true = force; false = skip
    gene_end_method:   'none',  // none | tes_window | gene_body
    gene_end_window:    500,    // bp upstream of TES to sample (tes_window method)
    gene_end_min_reads: 10      // min reads to include gene in gene_body scaling
  ]

  // Replicate Merging
  replicates = [
    merge:               false,  // Merge replicates after alignment (requires concordance check)
    concordance_min:     0.9,    // Minimum Pearson/Spearman correlation to allow merge
    concordance_method: 'pearson' // pearson | spearman
  ]

  qc = [
    enabled:       true,   // Enable/disable FastQC
    mapq:          10,
    dedup:         true,
    depth_max_cov: 0,
    fail_map_rate_below: null,  // Fail if mapping rate < value (e.g. 50); null = disabled
    fail_strand_min: null       // Fail if either strand fraction < value (e.g. 0.30); null = disabled
  ]

  pol = [
    contrasts: [],
    top_n:     100,
    plots:     true
  ]

  // Conda Environment Overrides
  conda_norm      = null
  conda_pol      = null
  conda_divergent = null
  conda_fgr       = null
  conda_sra       = null

  // GTF / Annotation Options
  gtf_path = null
  gtf_url  = null
  annotation_source = 'refseq'   // refseq (UCSC), ensembl, gencode
  annotation_exclude_biotypes = ''  // e.g. rRNA,tRNA
  annotation_chr_naming = 'none'    // none, add (Ensembl->UCSC), remove (UCSC->Ensembl)

  // SRA Download: ncbi (NCBI only), ena (ENA only), auto (try NCBI, fallback to ENA)
  sra_download_source = 'auto'
  fastq_gzip          = false    // Compress downloaded FASTQs with pigz
  sra_tmp             = null     // Temp directory for fasterq-dump (null = system default)
  sra_max_size        = '200G'   // Max prefetch size for SRA downloads
}

// ════════════════════════════════════════════════════════════════════════════
// GLOBAL PROCESS DEFAULTS
// ════════════════════════════════════════════════════════════════════════════

process {
  executor  = 'local'
  scratch   = true

  cpus   = { params.res.lightweightCpus() }
  memory = { params.res.moderateMemory(3) }
  time   = '24h'

  errorStrategy = { task.exitStatus in [137,143] ? 'retry' : 'terminate' }
  maxRetries    = 1
  maxErrors     = -1

  beforeScript = {
    """
    mkdir -p .tmp 2>/dev/null || true
    export TMPDIR="\${PWD}/.tmp"
    export OMP_NUM_THREADS=${task.cpus}
    export OPENBLAS_NUM_THREADS=${task.cpus}
    export MKL_NUM_THREADS=${task.cpus}
    export BOWTIE2_THREADS=${task.cpus}
    export SAMTOOLS_THREADS=${task.cpus}
    export BEDTOOLS_THREADS=${task.cpus}
    """
  }

  containerOptions = {
    "--cpus=${task.cpus} --memory=${task.memory.toBytes()} --label nf-task=${task.process.replace(':', '_')}"
  }
}

// ════════════════════════════════════════════════════════════════════════════
// PROCESS-SPECIFIC RESOURCE ALLOCATION
// ════════════════════════════════════════════════════════════════════════════

process {
  // Replicate Concordance Check & Merge (deepTools + samtools)
  withName: /(?i).*check_and_merge_replicates.*/ {
    cpus     = { params.res.analysisCpus() }
    memory   = { params.res.moderateMemory(6) }
    time     = '4h'
    maxForks = 2
  }

  // High-Intensity Processes
  withName: /(?i).*align_reads_to_genome.*/ {
    cpus     = { params.res.alignmentCpus() }
    memory   = { params.res.alignmentMemory() }
    time     = '8h'
    maxForks = Runtime.runtime.availableProcessors() < 8 ? 1 : Math.max(1, ((Runtime.runtime.availableProcessors() / 6) as int))
  }

  withName: /(?i).*download_genome_and_build_alignment_index.*/ {
    cpus     = { params.res.indexCpus() }
    memory   = { params.res.intensiveMemory(8) }
    time     = '6h'
    maxForks = 1
  }

  withName: /(?i).*normalize_coverage_tracks.*/ {
    cpus     = { params.res.normCpus() }
    memory   = { params.res.intensiveMemory(10) }
    time     = '8h'
    maxForks = Runtime.runtime.availableProcessors() < 10 ? 1 : Math.max(1, Math.min(3, ((Runtime.runtime.availableProcessors() / 8) as int)))
    scratch  = true
  }

  withName: /(?i).*detect_divergent_transcription.*/ {
    cpus          = { params.res.divergentCpus() }
    memory        = { params.res.intensiveMemory(10) }
    time          = '8h'
    maxForks = Runtime.runtime.availableProcessors() < 12 ? 1 : Math.max(1, Math.min(3, ((Runtime.runtime.availableProcessors() / 8) as int)))
    errorStrategy = { task.exitStatus in [137,143] ? 'retry' : 'terminate' }
    maxRetries    = 2
    scratch       = true
  }

  // Medium-Intensity Processes
  withName: /(?i).*preprocess_and_quality_filter_reads.*/ {
    cpus     = { params.res.preprocessCpus() }
    memory   = { params.res.moderateMemory(5) }
    time     = '4h'
    maxForks = Runtime.runtime.availableProcessors() < 6 ? 1 : Math.max(1, ((Runtime.runtime.availableProcessors() / 4) as int))
  }

  withName: /(?i).*generate_coverage_tracks.*/ {
    cpus     = { params.res.tracksCpus() }
    memory   = { params.res.moderateMemory(5) }
    time     = '6h'
    maxForks = Runtime.runtime.availableProcessors() < 6 ? 1 : Math.max(1, ((Runtime.runtime.availableProcessors() / 3) as int))
  }

  withName: /(?i).*calculate_polymerase_occupancy_metrics.*/ {
    cpus     = { params.res.analysisCpus() }
    memory   = { params.res.moderateMemory(5) }
    time     = '4h'
    maxForks = Math.max(2, ((Runtime.runtime.availableProcessors() / 3) as int))
  }

  withName: /(?i).*assign_signal_to_functional_regions.*/ {
    cpus     = { params.res.analysisCpus() }
    memory   = { params.res.moderateMemory(4) }
    time     = '4h'
    maxForks = Math.max(2, ((Runtime.runtime.availableProcessors() / 3) as int))
  }

  withName: /(?i)(quantify_reads_per_gene|quality_control_aligned_reads|summarize_polymerase_metrics).*/ {
    cpus     = { Math.min(2, Math.max(1, ((Runtime.runtime.availableProcessors() / 4) as int))) }
    memory   = { params.res.moderateMemory(3) }
    time     = '2h'
    maxForks = Math.max(4, ((Runtime.runtime.availableProcessors() / 2) as int))
  }

  // Lightweight Processes
  withName: /(?i).*download_genome_annotations.*/ {
    cpus     = { params.res.lightweightCpus() }
    memory   = { params.res.lightMemory() }
    time     = '4h'
    maxForks = 1
  }

  withName: /(?i).*download_sra_samples.*/ {
    cpus     = { Math.min(4, Math.max(2, ((Runtime.runtime.availableProcessors() / 4) as int))) }
    memory   = { params.res.moderateMemory(4) }
    time     = '6h'
    maxForks = Math.max(2, ((Runtime.runtime.availableProcessors() / 4) as int))
  }

  withName: /(?i)(generate_per_sample_reports|combine_reports_into_cohort).*/ {
    cpus     = { params.res.lightweightCpus() }
    memory   = { params.res.lightMemory() }
    time     = '1h'
    maxForks = Math.max(4, ((Runtime.runtime.availableProcessors() / 2) as int))
  }
}

// ════════════════════════════════════════════════════════════════════════════
// EXECUTION REPORTS
// ════════════════════════════════════════════════════════════════════════════

trace {
  enabled   = true
  file      = "${params.output_dir}/trace/trace.txt"
  sep       = '\t'
  fields    = 'task_id,hash,process,tag,cpus,memory,%cpu,%mem,rss,peak_rss,vmem,peak_vmem,realtime,duration,read_bytes,write_bytes,attempt,workdir'
  overwrite = true
}

report {
  enabled   = true
  file      = "${params.output_dir}/trace/report.html"
  overwrite = true
}

timeline {
  enabled   = true
  file      = "${params.output_dir}/trace/timeline.html"
  overwrite = true
}

dag {
  enabled   = true
  file      = "${params.output_dir}/trace/flow_dag.png"
  overwrite = true
}

// ════════════════════════════════════════════════════════════════════════════
// EXECUTION PROFILES
// ════════════════════════════════════════════════════════════════════════════

profiles {
  docker {
    docker.enabled    = true
    process.container = 'ghcr.io/serhataktay/tracktx:3.0'
  }

  conda {
    process.executor  = 'local'
    conda.enabled     = true
    process.conda     = "${projectDir}/envs/tracktx.yaml"
    conda.useMamba        = false
    conda.cacheDir        = "${System.getenv('NXF_CONDA_CACHEDIR') ?: projectDir + '/.conda'}"
    conda.createTimeout   = '2h'
    conda.createOptions   = '--no-channel-priority --repodata-fn=repodata.json'
  }

  conda_server {
    process.executor    = 'local'
    conda.enabled       = true
    params.publish_mode = 'copy'
    process.conda       = "${System.getenv('NXF_CONDA_ENV_PATH') ?: projectDir + '/envs/tracktx.yaml'}"
    conda.useMamba        = false
    conda.useMicromamba   = false
    conda.createTimeout   = '4h'
    conda.createOptions   = '--no-channel-priority --repodata-fn=repodata.json --copy'
    conda.cacheDir        = "${System.getenv('TMPDIR') ?: '/tmp'}/nextflow-conda-${System.getProperty('user.name')}"

    process {
      stageInMode = 'copy'
      scratch     = false
    }

    beforeScript = '''
      mkdir -p .tmp 2>/dev/null || true
      export TMPDIR="${PWD}/.tmp"
      mkdir -p "${CONDA_PKGS_DIRS}" || true
      chmod 755 "${CONDA_PKGS_DIRS}" || true
      find "${CONDA_PKGS_DIRS}" -name "*.lock" -mtime +1 -delete 2>/dev/null || true
      touch "${CONDA_PKGS_DIRS}/.write_test" && rm -f "${CONDA_PKGS_DIRS}/.write_test" || {
        echo "WARNING: Cannot write to ${CONDA_PKGS_DIRS}"
        export CONDA_PKGS_DIRS="/tmp/conda-emergency-${RANDOM}"
        mkdir -p "${CONDA_PKGS_DIRS}"
      }
      _conda_init=false
      if [ -n "${CONDA_EXE}" ] && [ -x "${CONDA_EXE}" ]; then
        eval "$(${CONDA_EXE} shell.bash hook 2>/dev/null)" && _conda_init=true
      fi
      if [ "$_conda_init" = "false" ] && command -v conda >/dev/null 2>&1; then
        eval "$(conda shell.bash hook 2>/dev/null)" && _conda_init=true
      fi
      if [ "$_conda_init" = "false" ]; then
        for conda_sh in \
          "${HOME}/miniconda3/etc/profile.d/conda.sh" \
          "${HOME}/anaconda3/etc/profile.d/conda.sh" \
          "${HOME}/mambaforge/etc/profile.d/conda.sh" \
          "/opt/conda/etc/profile.d/conda.sh"
        do
          [ -f "$conda_sh" ] && source "$conda_sh" && _conda_init=true && break
        done
      fi
      if [ "$_conda_init" = "false" ]; then
        echo "ERROR: Conda initialization failed - ensure conda is installed and in PATH"
        exit 1
      fi
    '''
  }

  singularity {
    singularity.enabled    = true
    singularity.autoMounts = true
    singularity.cacheDir   = "${baseDir}/.singularity"
    process.container      = 'docker://ghcr.io/serhataktay/tracktx:3.0'
    conda.enabled          = false
    singularity.runOptions = '--bind /tmp:/tmp --bind /var/tmp:/var/tmp --bind /scratch:/scratch --cleanenv --no-home'
  }

  apptainer {
    singularity.enabled    = true
    singularity.autoMounts = true
    singularity.cacheDir   = "${baseDir}/.singularity"
    process.container      = 'docker://ghcr.io/serhataktay/tracktx:3.0'
    conda.enabled          = false
    singularity.runOptions = '--bind /tmp:/tmp --bind /var/tmp:/var/tmp --bind /scratch:/scratch --cleanenv --no-home'
  }

  podman {
    podman.enabled    = true
    podman.enabled    = true
    process.container = 'ghcr.io/serhataktay/tracktx:3.0'
    conda.enabled     = false
  }

  local {
    process.executor  = 'local'
    conda.enabled     = false
  }

  slurm {
    process.executor = 'slurm'
    process.queue    = 'normal'
    // process.partition  = 'normal'             // Uncomment and set for your cluster
    // process.clusterOptions = '-A project_id'  // Uncomment for cluster-specific options
  }

  // Performance optimizations for external storage (USB, NAS, network drives)
  // Use: -profile docker,performance or ./run_pipeline.sh --external-drive
  performance {
    params {
      publish_mode = 'copy'  // Hard links fail on exFAT; copy works on all filesystems
    }
    process {
      scratch  = false
      maxForks = Math.max(8, Math.min(16, ((Runtime.runtime.availableProcessors() * 1.2) as int)))

      withName: /(?i).*align_reads_to_genome.*/ {
        maxForks = Math.max(2, ((Runtime.runtime.availableProcessors() / 4) as int))
        scratch  = false
      }
      withName: /(?i).*generate_coverage_tracks.*/ {
        maxForks = Math.max(2, ((Runtime.runtime.availableProcessors() / 2) as int))
        scratch  = false
      }
      withName: /(?i).*normalize_coverage_tracks.*/ {
        maxForks = Math.max(2, Math.min(4, ((Runtime.runtime.availableProcessors() / 4) as int)))
        scratch  = false
      }
      withName: /(?i).*detect_divergent_transcription.*/ {
        maxForks = Math.max(3, ((Runtime.runtime.availableProcessors() / 2) as int))
        scratch  = false
      }
      withName: /(?i).*preprocess_and_quality_filter_reads.*/ {
        maxForks = Math.max(2, ((Runtime.runtime.availableProcessors() / 3) as int))
        scratch  = false
      }
      withName: /(?i).*calculate_polymerase_occupancy_metrics.*/ {
        maxForks = Math.max(3, ((Runtime.runtime.availableProcessors() / 2) as int))
        scratch  = false
      }
      withName: /(?i).*assign_signal_to_functional_regions.*/ {
        maxForks = Math.max(3, ((Runtime.runtime.availableProcessors() / 2) as int))
        scratch  = false
      }
      withName: /(?i)(quantify_reads_per_gene|quality_control_aligned_reads|summarize_polymerase_metrics).*/ {
        maxForks = Math.max(6, ((Runtime.runtime.availableProcessors() * 1.5) as int))
        scratch  = false
      }
      withName: /(?i).*download_(genome_annotations|sra_samples).*/ {
        maxForks = Math.max(2, ((Runtime.runtime.availableProcessors() / 3) as int))
        scratch  = false
      }
      withName: /(?i)(generate_per_sample_reports|combine_reports_into_cohort).*/ {
        maxForks = Math.max(6, ((Runtime.runtime.availableProcessors() * 1.5) as int))
        scratch  = false
      }
      withName: /(?i).*download_genome_and_build_alignment_index.*/ {
        maxForks = 1
        scratch  = false
      }
    }

    executor {
      queueSize = 200
    }

    docker {
      remove = true
    }
  }
}
